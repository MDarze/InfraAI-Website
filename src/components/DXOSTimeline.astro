---
/**
 * DXOSTimeline.astro
 * Isometric-style 5-day DX-OS process timeline
 */
---

<svg viewBox="0 0 600 250" xmlns="http://www.w3.org/2000/svg" class="dxos-timeline">
  <!-- Background -->
  <defs>
    <style>
      .timeline-day { fill: var(--bg-elevated); stroke: var(--accent); stroke-width: 2; }
      .timeline-label { font-family: var(--font-body); font-size: 12px; font-weight: 600; fill: var(--ink-900); }
      .timeline-sublabel { font-family: var(--font-body); font-size: 10px; fill: var(--ink-500); }
      .timeline-line { stroke: var(--accent); stroke-width: 2; fill: none; }
      .timeline-arrow { stroke: var(--accent); stroke-width: 2; fill: none; }
    </style>
  </defs>

  <!-- Day 1: التشخيص (Diagnosis) -->
  <rect class="timeline-day" x="30" y="80" width="70" height="70" rx="8"/>
  <text class="timeline-label" x="65" y="115" text-anchor="middle">يوم 1</text>
  <text class="timeline-sublabel" x="65" y="135" text-anchor="middle">التشخيص</text>

  <!-- Arrow 1→2 -->
  <line class="timeline-line" x1="100" y1="115" x2="130" y2="115"/>
  <polygon points="135,115 130,112 130,118" fill="var(--accent)"/>

  <!-- Day 2: التحليل (Analysis) -->
  <rect class="timeline-day" x="130" y="80" width="70" height="70" rx="8"/>
  <text class="timeline-label" x="165" y="115" text-anchor="middle">يوم 2</text>
  <text class="timeline-sublabel" x="165" y="135" text-anchor="middle">التحليل</text>

  <!-- Arrow 2→3 -->
  <line class="timeline-line" x1="200" y1="115" x2="230" y2="115"/>
  <polygon points="235,115 230,112 230,118" fill="var(--accent)"/>

  <!-- Day 3: التصميم (Design) -->
  <rect class="timeline-day" x="230" y="80" width="70" height="70" rx="8"/>
  <text class="timeline-label" x="265" y="115" text-anchor="middle">يوم 3</text>
  <text class="timeline-sublabel" x="265" y="135" text-anchor="middle">التصميم</text>

  <!-- Arrow 3→4 -->
  <line class="timeline-line" x1="300" y1="115" x2="330" y2="115"/>
  <polygon points="335,115 330,112 330,118" fill="var(--accent)"/>

  <!-- Day 4: التقرير (Report) -->
  <rect class="timeline-day" x="330" y="80" width="70" height="70" rx="8"/>
  <text class="timeline-label" x="365" y="115" text-anchor="middle">يوم 4</text>
  <text class="timeline-sublabel" x="365" y="135" text-anchor="middle">التقرير</text>

  <!-- Arrow 4→5 -->
  <line class="timeline-line" x1="400" y1="115" x2="430" y2="115"/>
  <polygon points="435,115 430,112 430,118" fill="var(--accent)"/>

  <!-- Day 5: الخارطة (Roadmap) -->
  <rect class="timeline-day" x="430" y="80" width="70" height="70" rx="8"/>
  <text class="timeline-label" x="465" y="115" text-anchor="middle">يوم 5</text>
  <text class="timeline-sublabel" x="465" y="135" text-anchor="middle">الخارطة</text>

  <!-- Checkmark indicators -->
  <circle cx="50" cy="40" r="12" fill="var(--accent)" opacity="0.2"/>
  <circle cx="150" cy="40" r="12" fill="var(--accent)" opacity="0.2"/>
  <circle cx="250" cy="40" r="12" fill="var(--accent)" opacity="0.2"/>
  <circle cx="350" cy="40" r="12" fill="var(--accent)" opacity="0.2"/>
  <circle cx="450" cy="40" r="12" fill="var(--accent)" opacity="0.2"/>
</svg>

<style>
  :global(.dxos-timeline) {
    width: 100%;
    height: auto;
    max-width: 600px;
    margin: 0 auto;
  }
</style>
