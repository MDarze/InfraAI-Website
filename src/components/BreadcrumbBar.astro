---
/**
 * BreadcrumbBar.astro
 * Navigation breadcrumb component for sub-pages
 */

interface Props {
  pageTitle: string;
  lang?: string;
}

const { pageTitle, lang = 'ar' } = Astro.props;
const homeLabel = lang === 'ar' ? 'الرئيسية' : 'Home';
const homeHref = lang === 'ar' ? '/' : '/en/';
---

<nav class="breadcrumb-bar">
  <div class="container">
    <a href={homeHref} class="breadcrumb-link">
      <span class="breadcrumb-arrow">←</span>
      {homeLabel}
    </a>
    <span class="breadcrumb-separator">/</span>
    <span class="breadcrumb-current">{pageTitle}</span>
  </div>
</nav>

<style>
  .breadcrumb-bar {
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--divider-color);
    padding: var(--space-8) var(--gutter-sm);
  }

  .breadcrumb-bar .container {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-size: var(--fs-small);
    color: var(--ink-500);
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--ink-700);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-inout);
  }

  .breadcrumb-link:hover {
    color: var(--accent);
  }

  .breadcrumb-arrow {
    opacity: 0.6;
  }

  .breadcrumb-separator {
    opacity: 0.4;
  }

  .breadcrumb-current {
    font-weight: var(--fw-medium);
    color: var(--ink-700);
  }

  @media (min-width: 1280px) {
    .breadcrumb-bar {
      padding: var(--space-8) var(--gutter-lg);
    }
  }
</style>
