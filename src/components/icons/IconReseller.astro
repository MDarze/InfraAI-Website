---
/**
 * IconReseller.astro
 * Partnership / interlocking rings icon
 */
---

<svg
  viewBox="0 0 32 32"
  xmlns="http://www.w3.org/2000/svg"
  class="icon-reseller"
>
  <!-- Left ring -->
  <circle
    cx="12"
    cy="16"
    r="6"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    opacity="0.8"
  />

  <!-- Right ring -->
  <circle
    cx="20"
    cy="16"
    r="6"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    opacity="0.8"
  />

  <!-- Connection nodes -->
  <circle cx="12" cy="16" r="1.5" fill="currentColor" opacity="0.6" />
  <circle cx="20" cy="16" r="1.5" fill="currentColor" opacity="0.6" />

  <!-- Center bridge line -->
  <line x1="14.5" y1="16" x2="17.5" y2="16" stroke="currentColor" stroke-width="1.5" opacity="0.6" />
</svg>

<style>
  .icon-reseller {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
