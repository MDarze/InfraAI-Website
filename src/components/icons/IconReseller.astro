---
/**
 * IconReseller.astro
 * Two interlocking rings for partnership
 */
---

<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" class="icon-reseller">
  <!-- Left ring -->
  <circle cx="11" cy="16" r="7" fill="none" stroke="currentColor" stroke-width="1.5" />

  <!-- Right ring (overlapping) -->
  <circle cx="21" cy="16" r="7" fill="none" stroke="currentColor" stroke-width="1.5" />
</svg>

<style>
  :global(.icon-reseller) {
    width: 32px;
    height: 32px;
  }
</style>
