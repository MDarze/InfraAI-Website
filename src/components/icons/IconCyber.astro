---
/**
 * IconCyber.astro
 * Cybersecurity / shield icon with circuit pattern
 */
---

<svg
  viewBox="0 0 32 32"
  xmlns="http://www.w3.org/2000/svg"
  class="icon-cyber"
>
  <!-- Shield outline -->
  <path
    d="M 16 3 L 8 6.5 L 8 15 C 8 22 16 27 16 27 C 16 27 24 22 24 15 L 24 6.5 Z"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
  />

  <!-- Circuit line -->
  <line x1="10" y1="16" x2="14" y2="16" stroke="currentColor" stroke-width="1" opacity="0.6" />
  <line x1="14" y1="14" x2="14" y2="18" stroke="currentColor" stroke-width="1" opacity="0.6" />
  <line x1="14" y1="16" x2="18" y2="16" stroke="currentColor" stroke-width="1" opacity="0.6" />
  <line x1="18" y1="14" x2="18" y2="18" stroke="currentColor" stroke-width="1" opacity="0.6" />
  <line x1="18" y1="16" x2="22" y2="16" stroke="currentColor" stroke-width="1" opacity="0.6" />

  <!-- Small nodes -->
  <circle cx="14" cy="16" r="1.5" fill="currentColor" opacity="0.5" />
  <circle cx="18" cy="16" r="1.5" fill="currentColor" opacity="0.5" />
</svg>

<style>
  .icon-cyber {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
