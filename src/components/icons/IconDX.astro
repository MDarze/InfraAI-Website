---
/**
 * IconDX.astro
 * Abstract workflow grid icon for digital transformation
 */
---

<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" class="icon-dx">
  <!-- Grid of 3x3 squares -->
  <rect x="5" y="5" width="6" height="6" fill="none" stroke="currentColor" stroke-width="1.5" />
  <rect x="13" y="5" width="6" height="6" fill="none" stroke="currentColor" stroke-width="1.5" />
  <rect x="21" y="5" width="6" height="6" fill="none" stroke="currentColor" stroke-width="1.5" />

  <rect x="5" y="13" width="6" height="6" fill="none" stroke="currentColor" stroke-width="1.5" />
  <rect x="13" y="13" width="6" height="6" fill="currentColor" />
  <rect x="21" y="13" width="6" height="6" fill="none" stroke="currentColor" stroke-width="1.5" />

  <rect x="5" y="21" width="6" height="6" fill="none" stroke="currentColor" stroke-width="1.5" />
  <rect x="13" y="21" width="6" height="6" fill="none" stroke="currentColor" stroke-width="1.5" />
  <rect x="21" y="21" width="6" height="6" fill="none" stroke="currentColor" stroke-width="1.5" />

  <!-- Arrow pointing right -->
  <path d="M 24 28 L 28 28 L 26 26" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
</svg>

<style>
  :global(.icon-dx) {
    width: 32px;
    height: 32px;
  }
</style>
