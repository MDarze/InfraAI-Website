---
/**
 * IconDX.astro
 * Digital transformation / workflow icon
 */
---

<svg
  viewBox="0 0 32 32"
  xmlns="http://www.w3.org/2000/svg"
  class="icon-dx"
>
  <!-- Grid of boxes -->
  <rect x="4" y="6" width="5" height="5" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7" />
  <rect x="13" y="6" width="5" height="5" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7" />
  <rect x="22" y="6" width="5" height="5" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5" />

  <rect x="4" y="15" width="5" height="5" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7" />
  <rect x="13" y="15" width="5" height="5" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7" />
  <rect x="22" y="15" width="5" height="5" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5" />

  <rect x="4" y="24" width="5" height="5" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7" />
  <rect x="13" y="24" width="5" height="5" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7" />
  <rect x="22" y="24" width="5" height="5" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5" />

  <!-- Arrow indicating flow -->
  <path
    d="M 29 15 L 32 15 M 30 13.5 L 32 15 L 30 16.5"
    stroke="currentColor"
    stroke-width="1.5"
    fill="none"
    opacity="0.6"
  />
</svg>

<style>
  .icon-dx {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
