---
/**
 * IconAI.astro
 * Abstract neural network node icon for AI services
 */
---

<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" class="icon-ai">
  <!-- Center node -->
  <circle cx="16" cy="16" r="3" fill="currentColor" />

  <!-- Surrounding nodes -->
  <circle cx="10" cy="10" r="2" fill="currentColor" />
  <circle cx="22" cy="10" r="2" fill="currentColor" />
  <circle cx="10" cy="22" r="2" fill="currentColor" />
  <circle cx="22" cy="22" r="2" fill="currentColor" />
  <circle cx="16" cy="6" r="2" fill="currentColor" />
  <circle cx="16" cy="26" r="2" fill="currentColor" />

  <!-- Connection lines -->
  <line x1="16" y1="16" x2="10" y2="10" stroke="currentColor" stroke-width="1.5" />
  <line x1="16" y1="16" x2="22" y2="10" stroke="currentColor" stroke-width="1.5" />
  <line x1="16" y1="16" x2="10" y2="22" stroke="currentColor" stroke-width="1.5" />
  <line x1="16" y1="16" x2="22" y2="22" stroke="currentColor" stroke-width="1.5" />
  <line x1="16" y1="16" x2="16" y2="6" stroke="currentColor" stroke-width="1.5" />
  <line x1="16" y1="16" x2="16" y2="26" stroke="currentColor" stroke-width="1.5" />
</svg>

<style>
  :global(.icon-ai) {
    width: 32px;
    height: 32px;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
</style>
