---
/**
 * IconAI.astro
 * Neural network icon for AI/ML services
 */
---

<svg
  viewBox="0 0 32 32"
  xmlns="http://www.w3.org/2000/svg"
  class="icon-ai"
>
  <!-- Center node -->
  <circle cx="16" cy="16" r="3" fill="currentColor" opacity="0.8" />

  <!-- Surrounding nodes -->
  <circle cx="16" cy="5" r="2" fill="currentColor" opacity="0.6" />
  <circle cx="25" cy="10" r="2" fill="currentColor" opacity="0.6" />
  <circle cx="25" cy="22" r="2" fill="currentColor" opacity="0.6" />
  <circle cx="16" cy="27" r="2" fill="currentColor" opacity="0.6" />
  <circle cx="7" cy="22" r="2" fill="currentColor" opacity="0.6" />
  <circle cx="7" cy="10" r="2" fill="currentColor" opacity="0.6" />

  <!-- Connection lines -->
  <line x1="16" y1="16" x2="16" y2="5" stroke="currentColor" stroke-width="1" opacity="0.4" />
  <line x1="16" y1="16" x2="25" y2="10" stroke="currentColor" stroke-width="1" opacity="0.4" />
  <line x1="16" y1="16" x2="25" y2="22" stroke="currentColor" stroke-width="1" opacity="0.4" />
  <line x1="16" y1="16" x2="16" y2="27" stroke="currentColor" stroke-width="1" opacity="0.4" />
  <line x1="16" y1="16" x2="7" y2="22" stroke="currentColor" stroke-width="1" opacity="0.4" />
  <line x1="16" y1="16" x2="7" y2="10" stroke="currentColor" stroke-width="1" opacity="0.4" />
</svg>

<style>
  .icon-ai {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
