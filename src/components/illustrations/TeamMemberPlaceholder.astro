---
/**
 * TeamMemberPlaceholder.astro
 * Minimal person silhouette for team/about pages
 */
---

<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" class="team-placeholder">
  <defs>
    <style>
      .person-bg { fill: var(--accent); opacity: 0.12; }
      .person-shape { fill: var(--accent); opacity: 0.5; }
    </style>
  </defs>

  <!-- Circular crop background -->
  <circle class="person-bg" cx="100" cy="100" r="95"/>

  <!-- Person silhouette -->
  <!-- Head -->
  <circle class="person-shape" cx="100" cy="60" r="20"/>

  <!-- Shoulders/Torso -->
  <path class="person-shape" d="M 75 85 Q 75 105 85 125 L 115 125 Q 125 105 125 85 Q 112 75 100 75 Q 88 75 75 85"/>

  <!-- Accent circle outline -->
  <circle cx="100" cy="100" r="95" fill="none" stroke="var(--accent)" stroke-width="2" opacity="0.3"/>
</svg>

<style>
  :global(.team-placeholder) {
    width: 100%;
    height: auto;
    max-width: 200px;
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
  }
</style>
