---
import '../styles/global.css';
import BreadcrumbBar from '../components/BreadcrumbBar.astro';
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>اتصل بنا | InfraAI</title>
    <style>
      .nav { position: sticky; top: 0; z-index: 100; height: 64px; background: var(--nav-bg); backdrop-filter: var(--nav-blur); }
      .nav-content { display: flex; justify-content: space-between; align-items: center; height: 100%; padding-inline: var(--gutter-sm); }
      .logo, .nav-link { text-decoration: none; color: var(--ink-700); font-weight: 500; }
      .section { padding-block: var(--section-y-mobile); }
      .grid-2 { display: grid; grid-template-columns: 1fr; gap: var(--space-12); }
      @media (min-width: 1024px) { .grid-2 { grid-template-columns: 1fr 1fr; } }
      .contact-card { background: var(--bg-elevated); padding: var(--space-8); border-radius: var(--radius-lg); }
      .form-group { margin-block-end: var(--space-6); }
      .form-group label { display: block; margin-block-end: var(--space-2); font-weight: 500; }
      .form-group input, .form-group textarea { width: 100%; padding: 12px; border: 1px solid var(--ink-300); border-radius: var(--radius-sm); }
      .footer { background: var(--bg-elevated); border-top: 1px solid var(--divider-color); padding: var(--space-16) var(--gutter-sm); }
    </style>
  </head>

  <body>
    <nav class="nav">
      <div class="container nav-content">
        <a href="/" class="logo">InfraAI</a>
        <div><a href="/en/contact/">EN</a></div>
      </div>
    </nav>

    <BreadcrumbBar pageTitle="اتصل بنا" lang="ar" />

    <section class="section">
      <div class="container">
        <h1 style="margin-block-end: var(--space-8);">تواصل معنا</h1>
        <p style="font-size: var(--fs-h3); color: var(--ink-700); margin-block-end: var(--space-24);">
          نحن هنا للإجابة على جميع أسئلتك. تواصل معنا اليوم.
        </p>

        <div class="grid-2">
          <div>
            <h2 style="margin-block-end: var(--space-12);">معلومات الاتصال</h2>
            <div class="contact-card" style="margin-block-end: var(--space-8);">
              <h3 style="margin-block-end: var(--space-2);">العنوان</h3>
              <p style="color: var(--ink-700);">الرياض، السعودية</p>
            </div>
            <div class="contact-card" style="margin-block-end: var(--space-8);">
              <h3 style="margin-block-end: var(--space-2);">الهاتف</h3>
              <p><a href="tel:+966112222222" style="color: var(--accent);">+966 11 2222 2222</a></p>
            </div>
            <div class="contact-card">
              <h3 style="margin-block-end: var(--space-2);">البريد الإلكتروني</h3>
              <p><a href="mailto:sales@infraai-dx.co" style="color: var(--accent);">sales@infraai-dx.co</a></p>
            </div>
          </div>

          <div>
            <h2 style="margin-block-end: var(--space-12);">أرسل لنا رسالة</h2>
            <form id="contactForm" style="background: var(--bg-elevated); padding: var(--space-8); border-radius: var(--radius-lg);">
              <div class="form-group">
                <label>الاسم</label>
                <input type="text" required />
              </div>
              <div class="form-group">
                <label>البريد الإلكتروني</label>
                <input type="email" required />
              </div>
              <div class="form-group">
                <label>رقم الهاتف</label>
                <input type="tel" />
              </div>
              <div class="form-group">
                <label>الرسالة</label>
                <textarea rows="5" required></textarea>
              </div>
              <button type="submit" class="btn-primary" style="width: 100%;">أرسل الآن</button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="container">
        <p style="text-align: center; color: var(--ink-500); font-size: var(--fs-small);">&copy; 2024 InfraAI</p>
      </div>
    </footer>

    <script>
      document.getElementById('contactForm').addEventListener('submit', (e) => {
        e.preventDefault();
        alert('شكراً لك. سنرد عليك قريباً.');
      });
    </script>
  </body>
</html>
