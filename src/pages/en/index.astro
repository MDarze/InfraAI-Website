---
import '../../styles/global.css';

const BASE_URL = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="We consult. We execute. We transform. Digital transformation and cybersecurity services for Saudi companies." />
    <meta name="keywords" content="digital transformation, DX-OS, cybersecurity, Vision 2030" />
    <meta property="og:title" content="InfraAI Digital Solutions" />
    <meta property="og:description" content="Digital Transformation & Cybersecurity Services" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://infraai-dx.com/en/" />
    <link rel="canonical" href="https://infraai-dx.com/en/" />
    <link rel="alternate" hreflang="ar" href="https://infraai-dx.com/" />
    <title>InfraAI Digital Solutions | Expertise that Consults. Engineering that Delivers.</title>
    <style>
      /* Nav */
      .nav {
        position: sticky;
        top: 0;
        z-index: var(--nav-z);
        height: var(--nav-height);
        background: var(--nav-bg);
        backdrop-filter: var(--nav-blur);
        border-bottom: 1px solid transparent;
        transition: border-color var(--dur-base) var(--ease-inout);
      }

      .nav.scrolled {
        border-bottom-color: var(--nav-border-color);
      }

      .nav-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 100%;
        padding-inline: var(--gutter-sm);
      }

      @media (min-width: 1280px) {
        .nav-content {
          padding-inline: var(--gutter-lg);
        }
      }

      .logo {
        font-size: var(--fs-h3);
        font-weight: var(--fw-semi);
        color: var(--ink-900);
        text-decoration: none;
        font-family: var(--font-display);
      }

      .nav-links {
        display: flex;
        gap: var(--space-12);
        align-items: center;
        list-style: none;
      }

      .nav-link {
        font-size: var(--nav-link-size);
        font-weight: var(--nav-link-weight);
        color: var(--nav-link-color);
        text-decoration: none;
        transition: color var(--dur-fast) var(--ease-inout);
        font-family: var(--font-body);
      }

      .nav-link:hover {
        color: var(--nav-link-hover-color);
      }

      .lang-switch {
        background: var(--bg-elevated);
        border: none;
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-sm);
        font-size: var(--fs-small);
        font-weight: var(--fw-medium);
        color: var(--ink-900);
        cursor: pointer;
        transition: all var(--dur-fast) var(--ease-inout);
      }

      .lang-switch:hover {
        background: var(--bg-deep);
        color: var(--ink-000);
      }

      /* Hero */
      .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding-block: var(--space-24);
        background: var(--bg-canvas);
        overflow: hidden;
      }

      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: var(--hero-glow);
        z-index: 0;
        pointer-events: none;
      }

      .hero-content {
        position: relative;
        z-index: 1;
        max-width: 600px;
      }

      .hero h1 {
        font-size: var(--fs-hero);
        line-height: var(--lh-hero);
        margin-block-end: var(--space-8);
        animation: fadeInUp 0.8s var(--ease-out) forwards;
        opacity: 0;
        font-family: var(--font-display);
      }

      .hero p {
        font-size: clamp(1.125rem, 3vw, 1.25rem);
        color: var(--ink-700);
        margin-block-end: var(--space-12);
        animation: fadeInUp 0.8s var(--ease-out) 0.15s forwards;
        opacity: 0;
        font-family: var(--font-body);
      }

      .hero-ctas {
        display: flex;
        gap: var(--space-6);
        flex-wrap: wrap;
        margin-block-end: var(--space-12);
        animation: fadeInUp 0.8s var(--ease-out) 0.3s forwards;
        opacity: 0;
      }

      .hero-trust {
        font-size: var(--fs-small);
        color: var(--ink-500);
        animation: fadeInUp 0.8s var(--ease-out) 0.45s forwards;
        opacity: 0;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(24px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* Pillars Grid */
      .pillars {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: var(--space-12);
        margin-block-end: var(--space-32);
      }

      .pillar-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: var(--card-radius);
        padding: var(--card-padding);
        transition: var(--card-transition);
      }

      .pillar-card:hover {
        border-color: var(--card-border-hover);
        box-shadow: var(--card-shadow-hover);
        transform: var(--card-lift);
      }

      .pillar-icon {
        width: 64px;
        height: 64px;
        background: var(--accent-tint);
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-block-end: var(--space-6);
        font-size: 2rem;
      }

      .pillar-card h3 {
        margin-block-end: var(--space-3);
        font-family: var(--font-display);
      }

      .pillar-card p {
        color: var(--ink-500);
        margin-block-end: var(--space-6);
        line-height: var(--lh-relaxed);
        font-family: var(--font-body);
      }

      .pillar-link {
        color: var(--accent);
        font-weight: var(--fw-semi);
        text-decoration: none;
        transition: color var(--dur-fast) var(--ease-inout);
      }

      .pillar-link:hover {
        color: var(--accent-hover);
      }

      /* DX-OS Showcase */
      .dxos-section {
        background: var(--bg-deep);
        color: var(--ink-000);
        padding-block: var(--section-y-mobile);
        margin-block: var(--space-32) 0;
      }

      @media (min-width: 768px) {
        .dxos-section {
          padding-block: var(--section-y-tablet);
        }
      }

      @media (min-width: 1024px) {
        .dxos-section {
          padding-block: var(--section-y-desktop);
        }
      }

      .dxos-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-16);
        align-items: center;
      }

      @media (min-width: 1024px) {
        .dxos-grid {
          grid-template-columns: 1fr 1fr;
        }
      }

      .dxos-content h2 {
        color: var(--ink-000);
        margin-block-end: var(--space-6);
        font-family: var(--font-display);
      }

      .dxos-content p {
        color: var(--ink-000);
        opacity: 0.9;
        margin-block-end: var(--space-6);
        line-height: var(--lh-relaxed);
        font-family: var(--font-body);
      }

      .timeline {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--radius-lg);
        padding: var(--space-8);
        margin-block-top: var(--space-12);
      }

      .timeline-title {
        font-size: var(--fs-small);
        text-transform: uppercase;
        letter-spacing: var(--ls-caps);
        color: var(--accent-dark);
        margin-block-end: var(--space-6);
      }

      .timeline-steps {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
        gap: var(--space-4);
      }

      .timeline-step {
        text-align: center;
        padding: var(--space-4);
        border-radius: var(--radius-sm);
        background: rgba(0, 212, 168, 0.1);
        font-size: var(--fs-small);
      }

      .timeline-step-num {
        display: block;
        font-weight: var(--fw-semi);
        color: var(--accent-dark);
        font-size: var(--fs-h3);
        margin-block-end: var(--space-1);
      }

      /* Stats */
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: var(--space-12);
        margin-block: var(--space-32);
        padding: var(--space-16);
        background: var(--bg-elevated);
        border-radius: var(--radius-lg);
      }

      .stat {
        text-align: center;
      }

      .stat-number {
        font-size: clamp(2.5rem, 8vw, 3.5rem);
        font-weight: var(--fw-semi);
        color: var(--accent);
        line-height: 1;
        margin-block-end: var(--space-3);
        font-family: var(--font-display);
      }

      .stat-label {
        font-size: var(--fs-body);
        color: var(--ink-700);
        font-weight: var(--fw-medium);
        font-family: var(--font-body);
      }

      /* Services Summary */
      .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: var(--space-8);
        margin-block: var(--space-24);
      }

      .service-teaser {
        padding: var(--space-6);
        background: var(--bg-elevated);
        border-radius: var(--radius-lg);
        border: 1px solid var(--divider-color);
        transition: all var(--dur-base) var(--ease-inout);
        text-decoration: none;
      }

      .service-teaser:hover {
        border-color: var(--accent);
        transform: translateY(-2px);
      }

      .service-teaser h4 {
        color: var(--ink-900);
        margin-block-end: var(--space-2);
        font-family: var(--font-display);
      }

      .service-teaser p {
        font-size: var(--fs-small);
        color: var(--ink-500);
        font-family: var(--font-body);
      }

      /* Blog Cards */
      .insights-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: var(--space-12);
        margin-block: var(--space-24);
      }

      .insight-card {
        background: var(--bg-elevated);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-card);
        transition: var(--card-transition);
      }

      .insight-card:hover {
        box-shadow: var(--shadow-hover);
        transform: translateY(-4px);
      }

      .insight-image {
        width: 100%;
        height: 180px;
        background: var(--accent-tint);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
      }

      .insight-content {
        padding: var(--card-padding);
      }

      .insight-category {
        display: inline-block;
        background: var(--accent-tint);
        color: var(--accent);
        padding: var(--space-1) var(--space-3);
        border-radius: var(--radius-pill);
        font-size: var(--fs-micro);
        font-weight: var(--fw-semi);
        margin-block-end: var(--space-3);
      }

      .insight-content h3 {
        margin-block-end: var(--space-3);
        font-size: var(--fs-h3);
        font-family: var(--font-display);
      }

      .insight-content p {
        color: var(--ink-500);
        font-size: var(--fs-small);
        margin-block-end: var(--space-4);
        font-family: var(--font-body);
      }

      .insight-link {
        color: var(--accent);
        font-weight: var(--fw-semi);
        text-decoration: none;
      }

      /* CTA Bands */
      .cta-band {
        padding: var(--space-16) var(--space-12);
        background: var(--bg-elevated);
        border-radius: var(--radius-lg);
        border-left: 4px solid var(--accent);
        margin-block: var(--space-24);
        text-align: center;
      }

      .cta-band h3 {
        margin-block-end: var(--space-4);
        font-family: var(--font-display);
      }

      .cta-band p {
        margin-block-end: var(--space-8);
        color: var(--ink-700);
        font-family: var(--font-body);
      }

      .final-cta {
        background: var(--bg-deep);
        color: var(--ink-000);
        padding: var(--space-24) var(--space-12);
        margin-block-top: var(--space-32);
        text-align: center;
      }

      .final-cta h2 {
        color: var(--ink-000);
        margin-block-end: var(--space-12);
        font-family: var(--font-display);
      }

      .email-form {
        display: flex;
        gap: var(--space-4);
        max-width: 500px;
        margin-inline: auto;
        margin-block-end: var(--space-8);
        flex-wrap: wrap;
      }

      .email-input {
        flex: 1;
        min-width: 200px;
        padding: var(--space-3) var(--space-4);
        border: 1px solid var(--ink-300);
        border-radius: var(--radius-sm);
        font-size: var(--fs-body);
        font-family: var(--font-body);
      }

      .email-input::placeholder {
        color: var(--ink-300);
      }

      /* Footer */
      .footer {
        background: var(--bg-elevated);
        border-top: 1px solid var(--divider-color);
        padding: var(--space-16) var(--gutter-sm);
      }

      @media (min-width: 1280px) {
        .footer {
          padding: var(--space-16) var(--gutter-lg);
        }
      }

      .footer-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: var(--space-12);
        margin-block-end: var(--space-12);
      }

      .footer-col h4 {
        margin-block-end: var(--space-6);
        font-size: var(--fs-body);
        font-family: var(--font-display);
      }

      .footer-col ul {
        list-style: none;
      }

      .footer-col li {
        margin-block-end: var(--space-3);
      }

      .footer-col a {
        color: var(--ink-700);
        text-decoration: none;
        font-size: var(--fs-small);
        transition: color var(--dur-fast) var(--ease-inout);
        font-family: var(--font-body);
      }

      .footer-col a:hover {
        color: var(--accent);
      }

      .footer-bottom {
        border-top: 1px solid var(--divider-color);
        padding-top: var(--space-8);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: var(--fs-small);
        color: var(--ink-500);
        font-family: var(--font-body);
        flex-wrap: wrap;
        gap: var(--space-6);
      }
    </style>
  </head>

  <body>
    <!-- NAV -->
    <nav class="nav" id="nav">
      <div class="container nav-content">
        <a href={`${BASE_URL}/en/`} class="logo">InfraAI</a>
        <ul class="nav-links">
          <li><a href="#services" class="nav-link">Services</a></li>
          <li><a href="/en/about/" class="nav-link">About</a></li>
          <li><a href="/en/insights/" class="nav-link">Insights</a></li>
          <li><a href="/en/contact/" class="nav-link">Contact</a></li>
          <li><a href={`${BASE_URL}/`} class="lang-switch">AR</a></li>
        </ul>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <div class="container hero-content">
        <h1>We consult.</h1>
        <h1 style="font-size: var(--fs-h1);">We execute.</h1>
        <h1 style="font-size: var(--fs-h2);">We transform.</h1>
        <p>
          True digital transformation partners. We diagnose, implement, and build solutions that achieve Vision 2030.
        </p>
        <div class="hero-ctas">
          <button class="btn-primary" onclick="document.getElementById('contact').scrollIntoView({behavior: 'smooth'})">
            Book DX-OS Assessment
          </button>
          <button class="btn-secondary" onclick="document.getElementById('services').scrollIntoView({behavior: 'smooth'})">
            Explore Services
          </button>
        </div>
        <p class="hero-trust">
          ✓ Trusted by leading companies | ✓ Vision 2030 aligned
        </p>
      </div>
    </section>

    <!-- PILLARS -->
    <section id="services" style="padding-block: var(--section-y-mobile);">
      <div class="container">
        <h2 style="margin-block-end: var(--space-12);">Four Areas of Expertise</h2>
        <div class="pillars">
          <div class="pillar-card">
            <div class="pillar-icon">🤖</div>
            <h3>AI Transformation</h3>
            <p>Readiness assessment, use-case discovery, custom AI agents and GenAI integration.</p>
            <a href="/en/services/ai/" class="pillar-link">Learn More →</a>
          </div>
          <div class="pillar-card">
            <div class="pillar-icon">⚙️</div>
            <h3>Digital Transformation</h3>
            <p>DX-OS: comprehensive 5-day assessment plus digital operating model design.</p>
            <a href="/en/dxos/" class="pillar-link">Learn More →</a>
          </div>
          <div class="pillar-card">
            <div class="pillar-icon">🔐</div>
            <h3>Cybersecurity</h3>
            <p>Penetration testing, security operations, compliance readiness and red-team exercises.</p>
            <a href="/en/services/cybersecurity/" class="pillar-link">Learn More →</a>
          </div>
          <div class="pillar-card">
            <div class="pillar-icon">🤝</div>
            <h3>Reseller Program</h3>
            <p>Become our partner. Enterprise software licenses and cybersecurity tools.</p>
            <a href="/en/partners/" class="pillar-link">Learn More →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- DX-OS SHOWCASE -->
    <section class="dxos-section">
      <div class="container">
        <div class="dxos-grid">
          <div class="dxos-content">
            <h2>DX-OS: Digital Operating System</h2>
            <p>
              Our proprietary comprehensive assessment platform. Our engineers spend 5 days embedded in your company,
              analyzing operations deeply, delivering a report that covers transformation priorities, AI insights, and
              a redesigned operating model.
            </p>
            <p>
              100% Vision 2030 aligned. Starting from 10,000 SAR.
            </p>
            <a href="/en/dxos/" class="btn-primary" style="display: inline-block;">
              Explore DX-OS
            </a>

            <div class="timeline">
              <div class="timeline-title">The 5-Day Process</div>
              <div class="timeline-steps">
                <div class="timeline-step">
                  <span class="timeline-step-num">1</span>
                  Diagnosis
                </div>
                <div class="timeline-step">
                  <span class="timeline-step-num">2</span>
                  Analysis
                </div>
                <div class="timeline-step">
                  <span class="timeline-step-num">3</span>
                  Design
                </div>
                <div class="timeline-step">
                  <span class="timeline-step-num">4</span>
                  Report
                </div>
                <div class="timeline-step">
                  <span class="timeline-step-num">5</span>
                  Roadmap
                </div>
              </div>
            </div>
          </div>
          <div style="background: var(--accent-glow); border-radius: var(--radius-lg); min-height: 400px; display: flex; align-items: center; justify-content: center; color: var(--ink-000);">
            <div style="text-align: center;">
              <div style="font-size: 4rem; margin-block-end: var(--space-6);">📊</div>
              <p>DX-OS System Visualization</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section style="padding-block: var(--section-y-mobile);">
      <div class="container">
        <div class="stats-grid">
          <div class="stat">
            <div class="stat-number">5</div>
            <div class="stat-label">Days for comprehensive assessment</div>
          </div>
          <div class="stat">
            <div class="stat-number">100%</div>
            <div class="stat-label">Vision 2030 aligned</div>
          </div>
          <div class="stat">
            <div class="stat-number">4</div>
            <div class="stat-label">Specialized service areas</div>
          </div>
          <div class="stat">
            <div class="stat-number">+50</div>
            <div class="stat-label">Successful projects</div>
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICES SUMMARY -->
    <section style="padding-block: var(--section-y-mobile);">
      <div class="container">
        <h2 style="margin-block-end: var(--space-12);">Our Core Services</h2>
        <div class="services-grid">
          <a href="/en/services/ai/" class="service-teaser">
            <h4>AI Transformation</h4>
            <p>Readiness assessment, use-case discovery, and intelligent automation</p>
          </a>
          <a href="/en/dxos/" class="service-teaser">
            <h4>DX-OS Assessment</h4>
            <p>Comprehensive 5-day digital transformation evaluation</p>
          </a>
          <a href="/en/services/cybersecurity/" class="service-teaser">
            <h4>Cybersecurity</h4>
            <p>Penetration testing, security operations, and compliance</p>
          </a>
          <a href="/en/partners/" class="service-teaser">
            <h4>Reseller Program</h4>
            <p>Enterprise software and cybersecurity tool distribution</p>
          </a>
        </div>
      </div>
    </section>

    <!-- INSIGHTS PREVIEW -->
    <section style="padding-block: var(--section-y-mobile); background: var(--bg-subtle);">
      <div class="container">
        <h2 style="margin-block-end: var(--space-12);">Latest Insights</h2>
        <div class="insights-grid">
          <article class="insight-card">
            <div class="insight-image">📝</div>
            <div class="insight-content">
              <span class="insight-category">Digital Transformation</span>
              <h3>5 Steps to Begin Your Digital Transformation</h3>
              <p>A practical guide for business leaders looking to accelerate their digital transformation journey.</p>
              <a href="/en/insights/5-steps-digital-transformation/" class="insight-link">Read Article →</a>
            </div>
          </article>

          <article class="insight-card">
            <div class="insight-image">🤖</div>
            <div class="insight-content">
              <span class="insight-category">AI</span>
              <h3>How AI is Transforming Traditional Industries</h3>
              <p>Deep dive into AI applications in construction, infrastructure, and industrial sectors.</p>
              <a href="/en/insights/ai-transformation-industries/" class="insight-link">Read Article →</a>
            </div>
          </article>

          <article class="insight-card">
            <div class="insight-image">🔐</div>
            <div class="insight-content">
              <span class="insight-category">Cybersecurity</span>
              <h3>Understanding NCA ECC Compliance</h3>
              <p>What you need to know about Saudi Arabia's national cybersecurity standards and requirements.</p>
              <a href="/en/insights/nca-ecc-compliance/" class="insight-link">Read Article →</a>
            </div>
          </article>
        </div>
        <div style="text-align: center; margin-block-top: var(--space-12);">
          <a href="/en/insights/" class="btn-secondary">View All Articles</a>
        </div>
      </div>
    </section>

    <!-- FOUNDING CLIENT CTA -->
    <section style="padding-block: var(--section-y-mobile);">
      <div class="container">
        <div class="cta-band">
