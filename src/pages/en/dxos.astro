---
import '../../styles/global.css';
import BreadcrumbBar from '../../components/BreadcrumbBar.astro';
---

<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="DX-OS - نظام التشغيل الرقمي. تقييم شامل 5 أيام للتحول الرقمي من InfraAI." />
    <title>DX-OS | نظام التشغيل الرقمي للتحول</title>
    <link rel="canonical" href="https://infraai-dx.com/dxos/" />
    <link rel="alternate" hreflang="en" href="https://infraai-dx.com/en/dxos/" />
    <style>
      .nav { position: sticky; top: 0; z-index: 100; height: 64px; background: var(--nav-bg); backdrop-filter: var(--nav-blur); border-bottom: 1px solid transparent; transition: border-color var(--dur-base) var(--ease-inout); }
      .nav.scrolled { border-bottom-color: var(--nav-border-color); }
      .nav-content { display: flex; align-items: center; justify-content: space-between; height: 100%; padding-inline: var(--gutter-sm); }
      .logo { font-size: var(--fs-h3); font-weight: var(--fw-semi); color: var(--ink-900); text-decoration: none; }
      .nav-links { display: flex; gap: var(--space-12); list-style: none; }
      .nav-link { font-size: 0.9375rem; font-weight: 500; color: var(--ink-700); text-decoration: none; }
      .lang-switch { background: var(--bg-elevated); border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: var(--fs-small); }

      .hero { min-height: 70vh; display: flex; align-items: center; padding-block: var(--space-24); background: var(--bg-canvas); }
      .hero-content { max-width: 700px; }
      .hero h1 { font-size: var(--fs-h1); margin-block-end: var(--space-8); }
      .hero p { font-size: var(--fs-h3); color: var(--ink-700); margin-block-end: var(--space-12); }

      .section { padding-block: var(--section-y-mobile); }
      .section.dark { background: var(--bg-deep); color: var(--ink-000); }
      .section h2 { margin-block-end: var(--space-12); }
      .section h3 { margin-block-end: var(--space-6); }

      .grid-2 { display: grid; grid-template-columns: 1fr; gap: var(--space-16); }
      @media (min-width: 1024px) { .grid-2 { grid-template-columns: 1fr 1fr; } }

      .feature-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-12); margin-block: var(--space-24); }
      .feature { background: var(--bg-elevated); padding: var(--space-8); border-radius: var(--radius-lg); }
      .feature h4 { margin-block-end: var(--space-3); color: var(--ink-900); }
      .feature p { color: var(--ink-500); font-size: var(--fs-small); }

      .timeline-full { background: var(--bg-elevated); padding: var(--space-12); border-radius: var(--radius-lg); margin-block: var(--space-24); }
      .timeline-day { padding: var(--space-8); border-left: 3px solid var(--accent); margin-block-end: var(--space-6); }
      .timeline-day h4 { color: var(--ink-900); margin-block-end: var(--space-2); }
      .timeline-day p { color: var(--ink-700); font-size: var(--fs-small); line-height: var(--lh-relaxed); }

      .pricing-card { background: var(--bg-elevated); border: 2px solid var(--accent); border-radius: var(--radius-lg); padding: var(--space-12); text-align: center; }
      .pricing-number { font-size: clamp(2rem, 5vw, 3rem); font-weight: var(--fw-semi); color: var(--accent); margin-block-end: var(--space-2); }
      .pricing-label { color: var(--ink-700); margin-block-end: var(--space-12); }
      .pricing-features { text-align: start; margin-block: var(--space-12); }
      .pricing-features li { margin-block-end: var(--space-3); }

      .cta-section { background: var(--bg-deep); color: var(--ink-000); padding: var(--space-24) var(--space-12); text-align: center; border-radius: var(--radius-lg); margin-block: var(--space-24); }
      .cta-section h2 { color: var(--ink-000); }

      .footer { background: var(--bg-elevated); border-top: 1px solid var(--divider-color); padding: var(--space-16) var(--gutter-sm); }
      .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--space-12); margin-block-end: var(--space-12); }
      .footer-col h4 { margin-block-end: var(--space-6); }
      .footer-col a { color: var(--ink-700); font-size: var(--fs-small); text-decoration: none; }
      .footer-bottom { border-top: 1px solid var(--divider-color); padding-top: var(--space-8); color: var(--ink-500); font-size: var(--fs-small); }
    </style>
  </head>

  <body>
    <nav class="nav" id="nav">
      <div class="container nav-content">
        <a href="/" class="logo">InfraAI</a>
        <ul class="nav-links">
          <li><a href="/#services" class="nav-link">الخدمات</a></li>
          <li><a href="/about" class="nav-link">عن الشركة</a></li>
          <li><a href="/en/dxos/" class="lang-switch">EN</a></li>
        </ul>
      </div>
    </nav>

    <BreadcrumbBar pageTitle="DX-OS" lang="en" />

    <section class="hero">
      <div class="container hero-content">
        <h1>DX-OS</h1>
        <p>Comprehensive Digital Operating System</p>
        <p style="font-size: var(--fs-body); color: var(--ink-700); margin-block-end: var(--space-12);">
          5-day assessment covering all aspects of your digital operations. من التشخيص إلى خارطة الطريق.
        </p>
        <button class="btn-primary" onclick="document.getElementById('booking').scrollIntoView({behavior: 'smooth'})">احجز التقييم</button>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2>المشكلة</h2>
        <p style="font-size: var(--fs-h3); color: var(--ink-700); margin-block-end: var(--space-12);">
          تحتاج شركاتك إلى فهم عميق لحالتك الرقمية الحالية قبل أي خطوة تحول. لكن معظم الاستشاريين يأتون، يكتبون تقارير، ويرحلون.
        </p>
        <p style="color: var(--ink-700); line-height: var(--lh-relaxed); margin-block-end: var(--space-6);">
          نحن نختلف. نحن ندخل عمقاً إلى عملياتك، نقابل فريقك، نحلل سير العمل، ونخرج برؤى قابلة للتنفيذ وخارطة طريق واضحة.
        </p>
      </div>
    </section>

    <section class="section dark">
      <div class="container">
        <h2>الحل: DX-OS</h2>
        <div class="grid-2">
          <div>
            <h3>ما هو DX-OS؟</h3>
            <p>منصتنا الملكية للتقييم الشامل. مهندسونا يقضون 5 أيام في شركتك:</p>
            <ul style="margin-block-start: var(--space-6); margin-block-end: var(--space-12);">
              <li style="margin-block-end: var(--space-3);">✓ تحليل شامل للعمليات الحالية</li>
              <li style="margin-block-end: var(--space-3);">✓ تقييم مستوى التطور الرقمي</li>
              <li style="margin-block-end: var(--space-3);">✓ اكتشاف فرص الأتمتة والذكاء الاصطناعي</li>
              <li style="margin-block-end: var(--space-3);">✓ تقييم الامتثال لرؤية 2030</li>
              <li style="margin-block-end: var(--space-3);">✓ تصميم نموذج تشغيل رقمي جديد</li>
            </ul>
          </div>
          <div style="background: rgba(0, 184, 148, 0.1); border-radius: var(--radius-lg); padding: var(--space-8); display: flex; align-items: center; justify-content: center; min-height: 300px;">
            <div style="text-align: center;">
              <div style="font-size: 3rem; margin-block-end: var(--space-4);">📊</div>
              <p>تقرير DX-OS الشامل</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2>عملية التقييم 5 أيام</h2>
        <div class="timeline-full">
          <div class="timeline-day">
            <h4>اليوم 1: التشخيص</h4>
            <p>نلتقي بفريقك، نفهم التحديات الحالية، نمسح العمليات الأساسية.</p>
          </div>
          <div class="timeline-day">
            <h4>اليوم 2: التحليل</h4>
            <p>تحليل عميق للبيانات والعمليات. تقييم نضج التحول الرقمي.</p>
          </div>
          <div class="timeline-day">
            <h4>اليوم 3: التصميم</h4>
            <p>تصميم نموذج التشغيل الرقمي الجديد. تحديد أولويات التحول.</p>
          </div>
          <div class="timeline-day">
            <h4>اليوم 4 والـ 5: التقرير والخارطة</h4>
            <p>إعداد التقرير الشامل وخارطة الطريق التفصيلية مع أولويات التنفيذ والمؤشرات الرئيسية.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2>يشمل التقييم</h2>
        <div class="feature-grid">
          <div class="feature">
            <h4>تحليل العمليات</h4>
            <p>فهم عميق لسير العمل الحالي والاختناقات.</p>
          </div>
          <div class="feature">
            <h4>فرص الأتمتة</h4>
            <p>تحديد العمليات القابلة للأتمتة والذكاء الاصطناعي.</p>
          </div>
          <div class="feature">
            <h4>التقييم التكنولوجي</h4>
            <p>تقييم البنية التحتية والأنظمة الحالية.</p>
          </div>
          <div class="feature">
            <h4>الامتثال والأمان</h4>
            <p>تقييم الامتثال لرؤية 2030 والمتطلبات الأمنية.</p>
          </div>
          <div class="feature">
            <h4>المؤشرات الرئيسية</h4>
            <p>تحديد KPIs للقياس والمتابعة.</p>
          </div>
          <div class="feature">
            <h4>خارطة الطريق</h4>
            <p>خطة تنفيذية مرحلية مع جدول زمني وميزانية.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--bg-subtle);">
      <div class="container">
        <h2 style="text-align: center; margin-block-end: var(--space-24);">التسعير</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-12);">
          <div class="pricing-card">
            <div class="pricing-number">10,000</div>
            <div class="pricing-label">ريال سعودي</div>
            <p style="color: var(--ink-500); margin-block-end: var(--space-8);">الحد الأدنى للتقييم الشامل</p>
            <button class="btn-primary" style="width: 100%;" onclick="document.getElementById('booking').scrollIntoView({behavior: 'smooth'})">احجز الآن</button>
          </div>
          <div style="background: var(--bg-elevated); padding: var(--space-12); border-radius: var(--radius-lg); border: 2px solid var(--divider-color);">
            <h4>برنامج العميل المؤسس</h4>
            <p style="color: var(--ink-700); margin-block: var(--space-6);">
              أول 3 عملاء ← تقييم DX-OS مجاني بالكامل
            </p>
            <button class="btn-secondary" style="width: 100%;" onclick="document.getElementById('booking').scrollIntoView({behavior: 'smooth'})">تقدم الآن</button>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container cta-section" id="booking">
        <h2>جاهز للبدء؟</h2>
        <p style="margin-block-end: var(--space-12); color: var(--ink-000);">احجز تقييم DX-OS اليوم</p>
        <form style="max-width: 500px; margin-inline: auto;">
          <input type="email" placeholder="بريدك الإلكتروني" style="width: 100%; padding: 12px; margin-block-end: var(--space-6); border: 1px solid var(--ink-300); border-radius: var(--radius-sm);" />
          <button type="submit" class="btn-primary" style="width: 100%;">احجز التقييم</button>
        </form>
      </div>
    </section>

    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-col">
            <h4>الخدمات</h4>
            <ul style="list-style: none;">
              <li style="margin-block-end: var(--space-3);"><a href="/services/ai/">تحول الذكاء الاصطناعي</a></li>
              <li style="margin-block-end: var(--space-3);"><a href="/dxos/">DX-OS</a></li>
              <li><a href="/services/cybersecurity/">الأمن السيبراني</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>الشركة</h4>
            <ul style="list-style: none;">
              <li style="margin-block-end: var(--space-3);"><a href="/about/">عن InfraAI</a></li>
              <li style="margin-block-end: var(--space-3);"><a href="/portfolio/">المشاريع</a></li>
              <li><a href="/contact/">التواصل</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>الاتصال</h4>
            <ul style="list-style: none;">
              <li style="margin-block-end: var(--space-3);">الرياض، السعودية</li>
              <li style="margin-block-end: var(--space-3);"><a href="tel:+966112222222">+966 11 2222 2222</a></li>
              <li><a href="mailto:sales@infraai-dx.co">sales@infraai-dx.co</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2024 InfraAI. جميع الحقوق محفوظة.</p>
        </div>
      </div>
    </footer>

    <script>
      const nav = document.getElementById('nav');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 10) nav.classList.add('scrolled');
        else nav.classList.remove('scrolled');
      });
    </script>
  </body>
</html>
