8:["$","$L9",null,{"locale":"ar","now":"$D2026-04-17T00:56:52.979Z","timeZone":"UTC","messages":{"nav":{"home":"الرئيسية","aiTransformation":"التحول بالذكاء الاصطناعي","cybersecurity":"الأمن السيبراني","industries":"القطاعات","trackRecord":"سابقة الأعمال","about":"عن الشركة","insights":"المقالات","contact":"تواصل معنا","bookAssessment":"احجز تقييماً","langSwitch":"EN"},"footer":{"company":"الشركة","services":"الخدمات","contact":"التواصل","legal":"InfraAI Digital Solutions · شركة ذات مسؤولية محدودة · السجل التجاري: 7053788142 · © 2026","email":"sales@infraai-dx.com","phone":"+966 53 749 7934","address":"الرياض، المملكة العربية السعودية"},"home":{"eyebrow":"INFRAAI · RIYADH · EST. MARCH 2026","headline":"نبني الذكاء داخل المؤسسة","subline":"شركة سعودية متخصصة في التحول بالذكاء الاصطناعي والأمن السيبراني. نعمل مع الجهات السيادية والمؤسسات الكبرى لتحويل العمليات من الداخل — لا من الخارج.","ctaPrimary":"احجز تقييماً ميدانياً","ctaSecondary":"تحدث مع فريقنا","foundingNote":"برنامج العملاء المؤسسين — تقييم مجاني لأول ٣ عملاء","prop1Title":"تقييم ميداني بالذكاء الاصطناعي","prop1Body":"نزول ميداني بتطبيقنا الخاص DX-OS لمدة ٥ أيام، يخرج بتقرير تحولي شامل.","prop2Title":"تنفيذ متكامل","prop2Body":"بناء الأنظمة الذكية، تكاملها مع منظومتك، وتدريب فريقك على التشغيل.","prop3Title":"أمن سيبراني سيادي","prop3Body":"عبر شراكاتنا مع رواد الأمن السيبراني في المملكة ومصر.","trackTitle":"فريقنا نفّذ في:","trackDisclaimer":"الأعمال المذكورة نُفّذت بواسطة الفريق المؤسس في أدوارهم السابقة. InfraAI شركة ناشئة تأسست في مارس 2026 — السجل التجاري رقم 7053788142.","spec1Title":"التحول بالذكاء الاصطناعي","spec1Body":"تقييم، تصميم، تنفيذ، وتشغيل سير العمل الذكية في أي قطاع.","spec2Title":"الأمن السيبراني","spec2Body":"حلول سيادية متكاملة عبر شراكات نخبة في المملكة ومصر.","foundingTitle":"برنامج العملاء المؤسسين","foundingBody":"أول ٣ عملاء يحصلون على تقييم ميداني مجاني كامل بقيمة ١٠٠٠٠ ريال، مقابل خطاب توصية اختياري بعد التنفيذ.","foundingCta":"تقدّم الآن — ٣ أماكن فقط","track1":"وزارة الداخلية السعودية","track2":"نوبكو (NUPCO)","track3":"وزارة السياحة المصرية","track4":"وزارة الآثار المصرية","track5":"غرفة عمليات الاحتيال المالي","track6":"منظومات الحوكمة الرقمية السيادية"},"ai":{"headline":"لا نستشير من بعيد. نبني من الداخل.","subline":"تقييم ميداني شامل بتقنية DX-OS، يتبعه تنفيذ متكامل لأنظمة الذكاء الاصطناعي.","method1":"اليوم 1–4: نزول ميداني","method1Body":"مقابلات الفريق، مسح سير العمل، تحليل البيانات، وتوثيق حالة التحول الرقمي الحالية.","method2":"اليوم 5: التقرير التحولي","method2Body":"تقرير شامل بالذكاء الاصطناعي يتضمن الفجوات، الفرص، والخارطة الكاملة للتحول.","reportTitle":"ما يحتويه التقرير","modelTitle":"النموذج الثلاثي","model1":"استشارة ميدانية مدعومة بـ DX-OS","model1Price":"١٠٬٠٠٠ ريال سعودي","model2":"تنفيذ White-Label مخصص","model2Body":"بناء وتكامل أنظمة ذكية مخصصة لعملياتك.","model3":"منتج SaaS بالذكاء الاصطناعي","model3Body":"حلول برمجية جاهزة للتوسع عبر قطاعات متعددة.","sectorsTitle":"القطاعات"},"cyber":{"headline":"أمن سيبراني سيادي — عبر شراكات نخبة.","subline":"InfraAI ليست بائع حلول أمنية. نحن طبقة التكامل والتنسيق.","positionBody":"نعمل مع رواد الأمن السيبراني في المملكة ومصر لتقديم حلول سيادية متكاملة لعملائنا. عميل واحد، عقد واحد، مسؤولية واحدة.","modelTitle":"نموذج الشراكة","capTitle":"القدرات","whyTitle":"لماذا عبر InfraAI؟","partnerTitle":"الشركاء","partnerBody":"نتشارك مع شركات رائدة في المملكة ومصر — تُكشف هوياتهم بموجب اتفاقيات سرية للعملاء المؤهلين."},"about":{"headline":"بُنينا لسد الفجوة","story":"تأسست InfraAI برؤية واحدة: أن المؤسسات السعودية والخليجية لا تحتاج استشارات من بعيد — تحتاج شركاء ينزلون الميدان، يبنون الأنظمة، ويشغّلونها حتى تعمل.","story2":"اجتمع مؤسسو الشركة بعد سنوات من العمل داخل مشاريع التحول الرقمي والذكاء الاصطناعي في الجهات السيادية في المملكة ومصر — من وزارة الداخلية السعودية إلى وزارتَي السياحة والآثار المصريتين، مروراً بنوبكو والقطاع الطبي.","story3":"اكتشفنا أن الفجوة ليست في التقنية — بل في من يمتلك الخبرة والعمق الميداني والشبكة المحلية معاً. InfraAI بُنيت لسد هذه الفجوة.","teamTitle":"الفريق المؤسس","f1Name":"محمد دراز","f1Title":"الرئيس التنفيذي والمؤسس","f1Tag":"مهندس منتجات ذكاء اصطناعي، خبرة في المشاريع السيادية السعودية والمصرية","f2Name":"عبدالله أبو عبثان","f2Title":"شريك مؤسس — تطوير الأعمال والعلاقات الحكومية","f2Tag":"خبرة عميقة في السوق السعودي والعلاقات المؤسسية","f3Name":"علي أبو عبثان","f3Title":"شريك استراتيجي — الحوكمة والتقنيات المتقدمة","f3Tag":"تخصص في أطر الحوكمة الرقمية والتقنيات الناشئة","f4Name":"أحمد ماهر","f4Title":"المدير التشغيلي وخبير الميدان","f4Tag":"١٥ عاماً في قطاع الإنشاءات السعودي وإدارة المشاريع الضخمة","legalTitle":"البيانات القانونية","crLabel":"السجل التجاري","crValue":"7053788142","dateLabel":"تاريخ الإصدار","dateValue":"01/03/2026","statusLabel":"الحالة","statusValue":"نشط","entityLabel":"النوع القانوني","entityValue":"شركة ذات مسؤولية محدودة"},"track":{"headline":"سابقة أعمال الفريق المؤسس","subline":"InfraAI شركة جديدة. فريقها ليس كذلك. فيما يلي المشاريع التي نفّذها شركاؤنا المؤسسون في أدوارهم السابقة قبل تأسيس الشركة.","disclaimer":"جميع الأعمال المذكورة نُفّذت في أدوار سابقة قبل تأسيس InfraAI. تُقدَّم كسابقة خبرة للفريق المؤسس، لا كمشاريع للشركة.","p1Title":"غرفة عمليات الاحتيال المالي — وزارة الداخلية السعودية","p1Role":"مدير منتج / محلل أعمال","p1Body":"تصميم سير العمل بين ٨ جهات سعودية: SSP، CST، MOC، NIC، SAMA، CMA، NCA، وGCAM. توثيق شامل حقل بحقل لمنظومة الطلب والاستجابة ذات الطابع السيادي.","p2Title":"خدمة حجز وتسليم المركبات — وزارة الداخلية السعودية","p2Role":"مدير منتج / محلل أعمال","p2Body":"توثيق سير عمل الحجز والتسليم متعدد الجهات لمركبات الدولة بمعايير سيادية صارمة.","p3Title":"التحول الرقمي — وزارة السياحة المصرية","p3Role":"تحول رقمي على المستوى الوطني","p3Body":"تحديث منظومة الخدمات الرقمية لوزارة السياحة المصرية على المستوى الوطني الشامل.","p4Title":"التحول الرقمي — وزارة الآثار المصرية","p4Role":"تحول رقمي للتراث الثقافي","p4Body":"رقمنة منظومة إدارة التراث الثقافي والآثار على المستوى الوطني.","p5Title":"نوبكو (NUPCO) — القطاع الطبي السعودي","p5Role":"تحول رقمي للقطاع الصحي","p5Body":"تحويل منظومة المشتريات والعمليات الصحية رقمياً لأكبر شركة مشتريات صحية في المملكة.","p6Title":"منصة Remora للتداول بالنسخ","p6Role":"بناء منتج من الصفر","p6Body":"بناء منصة تداول بالنسخ من الصفر وتطويرها حتى الإطلاق في Squadio."},"industries":{"headline":"القطاعات التي نخدمها","subline":"خبرة ميدانية حقيقية في قطاعات المملكة الاستراتيجية.","ind1Title":"الإنشاءات والمقاولات","ind1Body":"أكثر من ٨٥٠ شركة إنشاءات سعودية متوسطة الحجم، وسوق تحول رقمي يبلغ ٥ مليار ريال بحلول ٢٠٣٠. خبرة ميدانية مباشرة من المدير التشغيلي أحمد ماهر.","ind2Title":"القطاع الطبي والصحي","ind2Body":"نظام إدارة عيادات أطفال الأنابيب جاهز للإطلاق. خبرة مباشرة في NUPCO أكبر منصة مشتريات صحية سعودية.","ind3Title":"البنوك والخدمات المالية","ind3Body":"الذكاء الاصطناعي في كشف الاحتيال، تحسين العمليات، وأتمتة الامتثال. خبرة ميدانية في غرفة عمليات الاحتيال المالي بوزارة الداخلية.","ind4Title":"الجهات الحكومية والسيادية","ind4Body":"إدارة مشاريع التحول الرقمي السيادي، التوافق مع رؤية ٢٠٣٠، وإدارة العمل بين الجهات الحكومية."},"insights":{"headline":"المقالات والتحليلات","coming":"قريباً — مقالات وتحليلات من فريقنا حول الذكاء الاصطناعي والأمن السيبراني في السوق الخليجي."},"contact":{"headline":"تواصل مع فريقنا","subline":"سواء كنت مهتماً ببرنامج العملاء المؤسسين أو تريد معرفة المزيد — نحن هنا.","nameLabel":"الاسم الكامل","companyLabel":"الشركة","roleLabel":"المسمى الوظيفي","emailLabel":"البريد الإلكتروني","phoneLabel":"رقم الهاتف","sectorLabel":"القطاع","interestLabel":"موضوع التواصل","messageLabel":"رسالتك","submit":"أرسل الرسالة","int1":"التحول بالذكاء الاصطناعي","int2":"الأمن السيبراني","int3":"برنامج العملاء المؤسسين","int4":"أخرى","successMsg":"شكراً — سنرد عليك خلال ٢٤ ساعة.","sectors":["الإنشاءات","الصحة","البنوك والمال","الحكومة","التجزئة","أخرى"]}},"children":[["$","$La",null,{"locale":"en"}],["$","main",null,{"children":["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","$4","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","